  "script": "export const meta = { name: 'camiel-a02-impl', description: 'Implement alpha-v0.0.2 for Project-Camiel Godot game', phases: [{ title: 'Alpha v0.0.2' }] };\n\nconst P = '/Volumes/T9/Code/projects/Project-Camiel';\n\nphase('Alpha v0.0.2');\n\nconst r = await agent('Implement alpha-v0.0.2 for Project-Camiel (Godot 4 / GDScript) at ' + P + '. Read docs/roadmap.md, scripts/intro_scene.gd, scripts/camiel_controller.gd, scenes/main.tscn, project.godot first. Then create ALL of the following files with FULL correct GDScript/tscn content:\\n\\n1. scripts/main_menu.gd:\\nextends Node2D\\nvar version_label = \"alpha-v0.0.2\"\\nfunc _ready():\\n    # Position and configure the Start button\\n    pass\\nfunc _input(event):\\n    if event is InputEventKey and event.pressed and event.keycode == KEY_ENTER:\\n        get_tree().change_scene_to_file(\"res://scenes/main.tscn\")\\n\\n2. scenes/main_menu.tscn:\\n[gd_scene load_steps=2 format=3 uid=\"uid://b8mainmenu\"]\\n[ext_resource type=\"Script\" path=\"res://scripts/main_menu.gd\" id=\"1\"]\\n[node name=\"MainMenu\" type=\"Node2D\"]\\nscript = ExtResource(\"1\")\\n[node name=\"ColorRect\" type=\"ColorRect\" parent=\".\"]\\nanchors_preset = 15\\nanchor_right = 1.0\\nanchor_bottom = 1.0\\ncolor = Color(0.2, 0.4, 0.6, 1.0)  # gentle blue background\\n[node name=\"VBox\" type=\"VBoxContainer\" parent=\"ColorRect\"]\\nanchors_preset = 8\\nanchor_left = 0.5\\nanchor_top = 0.5\\nanchor_right = 0.5\\nanchor_bottom = 0.5\\noffset_left = -200.0\\noffset_top = -150.0\\noffset_right = 200.0\\noffset_bottom = 150.0\\n[node name=\"Title\" type=\"Label\" parent=\"ColorRect/VBox\"]\\ntext = \"Camiel\"\\nhorizontal_alignment = 1\\nvertical_alignment = 1\\n[node name=\"StartButton\" type=\"Button\" parent=\"ColorRect/VBox\"]\\ntext = \"Start!\"\\n[node name=\"VersionLabel\" type=\"Label\" parent=\"ColorRect/VBox\"]\\ntext = \"alpha-v0.0.2\"\\n\\n3. scripts/audio_manager.gd:\\nextends Node\\nvar bgm_player: AudioStreamPlayer\\nvar sfx_player: AudioStreamPlayer\\n\\nfunc _ready():\\n    bgm_player = AudioStreamPlayer.new()\\n    sfx_player = AudioStreamPlayer.new()\\n    add_child(bgm_player)\\n    add_child(sfx_player)\\n    # Buses: make sure Master and SFX exist in project.godot audio config\\n\\nfunc play_music():\\n    # Load and play assets/audio/bgm_ambient.ogg (or skip if file missing)\\n    pass\\n\\nfunc stop_music():\\n    bgm_player.stop()\\n\\nfunc play_sfx(sfx_name: String):\\n    # Load sfx from assets/audio/ dir, play once\\n    # sfx_collect.ogg, sfx_finish.ogg\\n    pass\\n\\n4. assets/audio/README.md:\\n# Audio Assets Required\\nReplace these placeholder references with actual audio files:\\n- bgm_ambient.ogg — looping gentle background music\\n- sfx_collect.ogg — short collect sound (star pickup)\\n- sfx_finish.ogg — finish marker reached sound\\n\\n5. scripts/collectible.gd:\\nextends Area2D\\nsignal collected\\n@onready var sprite = $Sprite2D\\nvar collected = false\\n\\nfunc _ready():\\n    var tween = create_tween().set_loops()\\n    tween.tween_property(sprite, \"scale\", Vector2(1.1, 1.1), 0.5)\\n    tween.tween_property(sprite, \"scale\", Vector2(1.0, 1.0), 0.5)\\n\\nfunc _on_body_entered(body):\\n    if not collected and body is CharacterBody2D:\\n        collected = true\\n        hide()\\n        # queue_free() after short delay so animation plays\\n        AudioManager.play_sfx(\"sfx_collect\")\\n        collected.emit()\\n        print(\"Collectible picked up!\")\\n\\n6. scenes/collectible.tscn:\\n[gd_scene load_steps=2 format=3 uid=\"uid://b8collect\"]\\n[ext_resource type=\"Script\" path=\"res://scripts/collectible.gd\" id=\"1\"]\\n[node name=\"Collectible\" type=\"Area2D\"]\\nscript = ExtResource(\"1\")\\n[node name=\"CollisionShape2D\" type=\"CollisionShape2D\" parent=\".\"]\\n[node name=\"Sprite2D\" type=\"Sprite2D\" parent=\".\"]\\n# Note: requires assets/collectibles/star.png — create a placeholder ColorRect sprite if missing\\n\\n7. scripts/hud.gd:\\nextends CanvasLayer\\n@onready var star_label = $StarCount\\nvar star_count = 0\\n\\nfunc _ready():\\n    star_label.text = \"Stars: 0\"\\n\\nfunc increment_stars():\\n    star_count += 1\\n    star_label.text = \"Stars: \" + str(star_count)\\n\\n8. scripts/finish_marker.gd:\\nextends Area2D\\nsignal finished\\n@onready var anim = $AnimatedSprite2D\\n\\nfunc _on_body_entered(body):\\n    if body is CharacterBody2D:\\n        finished.emit()\\n        AudioManager.play_sfx(\"sfx_finish\")\\n        # Show \"Goed zo!\" message\\n        var label = Label.new()\\n        label.text = \"Goed zo!\"\\n        label.position = Vector2(500, 300)\\n        add_child(label)\\n        await get_tree().create_timer(3.0).timeout\\n        get_tree().change_scene_to_file(\"res://scenes/main_menu.tscn\")\\n\\n9. scenes/finish_marker.tscn:\\n[gd_scene load_steps=2 format=3 uid=\"uid://b8finish\"]\\n[ext_resource type=\"Script\" path=\"res://scripts/finish_marker.gd\" id=\"1\"]\\n[node name=\"FinishMarker\" type=\"Area2D\"]\\nscript = ExtResource(\"1\")\\n[node name=\"CollisionShape2D\" type=\"CollisionShape2D\" parent=\".\"]\\n[node name=\"AnimatedSprite2D\" type=\"AnimatedSprite2D\" parent=\".\"]\\n\\n10. Update scenes/main.tscn to add:\\n- An instance of Collectible (positioned at a good spot)\\n- An instance of FinishMarker (positioned at far right of level)\\n- An instance of HUD (CanvasLayer)\\n\\nAlso update project.godot to:\\n- Add \"res://scenes/main_menu.tscn\" to the [scenes] list\\n- Add AudioManager to [autoload]\\n- Add Accessibility to [autoload] (create scripts/accessibility.gd too)\\n\\nReturn FULL contents of every new/modified file.', { label: 'a02-impl', tier: 'medium', cwd: P });\n\nreturn { ok: true, result: r };",
