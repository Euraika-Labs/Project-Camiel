; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Camiel beta-1-candidate"
run/main_scene="res://scenes/title_screen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

AudioManager="res://scripts/audio_manager.gd"
Accessibility="res://scripts/accessibility.gd"
ProgressTracker="res://scripts/progress_tracker.gd"

[input]

ui_focus_next={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"store_command":true,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194326,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}
ui_focus_prev={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"store_command":true,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194325,"key_label":0,"unicode":0,"echo":false,"script":null)
]
}
mobile_jump={
"deadzone": 0.5,
"events": []
}
jump={
"deadzone": 0.5,
"events": []
}
sit={
"deadzone": 0.5,
"events": []
}
sleep={
"deadzone": 0.5,
"events": []
}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

textures/vram_compression/import_etc2_astc=true

[audio]

audio/enable_audio_on_mobile=true

[audio_bus_layout]

bus/0/name="Master"
bus/0/volume_db=0.0
bus/0/send=""
bus/1/name="SFX"
bus/1/volume_db=0.0
bus/1/send="Master"
